{
  "name": "anilist-ultimate",
  "version": "2.0.0",
  "description": "The ultimate Anilist extension suite - Modern rewrite with TypeScript and Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\""
  },
  "keywords": [
    "anilist",
    "anime",
    "calendar",
    "chrome-extension"
  ],
  "author": "ExAstra",
  "license": "GPL-3.0",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.268",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.2.5",
    "terser": "^5.46.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  }
}
