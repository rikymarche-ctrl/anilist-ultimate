{
  "manifest_version": 3,
  "key": "",
  "name": "Anilist Ultimate",
  "version": "2.0.0",
  "description": "The ultimate Anilist extension suite. Modern calendar, hover comments, and more.",
  "author": "ExAstra",
  "homepage_url": "https://github.com/rikymarche-ctrl/anilist-ultimate",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://anilist.co/*",
    "https://graphql.anilist.co/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Anilist Ultimate",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://anilist.co/*"],
      "js": ["src/main.ts"],
      "css": [
        "src/styles/main.css",
        "src/styles/toast.css",
        "src/styles/calendar.css",
        "src/styles/settings-panel.css",
        "src/styles/social-activity.css",
        "src/styles/custom-lists.css",
        "src/styles/astra.css",
        "src/styles/activity-enhancer.css",
        "src/styles/activity-score.css",
        "src/styles/forum-enhancer.css",
        "src/styles/hover-comments.css",
        "src/styles/notification-cleaner.css",
        "src/styles/review-enhancer.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "assets/*", "src/styles/*.css"],
      "matches": ["https://anilist.co/*"]
    }
  ]
}
